  "keyFeatures": [
    "Uses real PostgreSQL parser (pg_query_go) for accurate SQL parsing",
    "15 built-in rules detecting anti-patterns and correctness issues",
    "No running database required - static analysis only",
    "Supports file, directory, and stdin input",
    "JSON and text output formats for CI integration",
    "Extensible rule system for custom checks",
    "Fast CGO-based parsing with embedded PostgreSQL parser"
  ],
  "publicApiSurface": [
    "pgvet [flags] <file-or-dir>...",
    "--format (text|json)",
    "--rules <rule-list>",
    "--exclude <rule-list>",
    "Rule interface: Name(), Description(), Check()",
    "Analyzer.New(rules)",
    "Analyzer.AnalyzePaths(paths)",
    "Analyzer.AnalyzeStdin(sql)",
    "walker.Walk(node, visitor)",
    "rule.All() - default rules",
    "rule.Extra() - opt-in rules",
    "rule.AllIncludingExtra() - all rules"
  ]
